# ============================================
# VOLTARIA NEXUS - Environment Variables
# ============================================

# --------------------------------------------
# BOT CONFIGURATION
# --------------------------------------------
BOT_NAME=VOLTARIA
BOT_VERSION=3.4.0
PREFIX=§

# --------------------------------------------
# WHATSAPP AUTHENTICATION
# --------------------------------------------
# No keys needed - uses LocalAuth with WhatsApp Web

# --------------------------------------------
# MYANIMELIST API (Required for Anime Commands)
# --------------------------------------------
# Get from: https://myanimelist.net/apiconfig
MAL_CLIENT_ID=a0bf78059b65fbc773b77cdc7c5232dc
MAL_CLIENT_SECRET=018cd7ff7224ced8b824b8346db370b443cf3e834db38f57f055a2fbe6eefbc1

# --------------------------------------------
# OPENAI API (Required for AI Commands)
# --------------------------------------------
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------
# MONGODB (Optional - for Economy/Warns)
# --------------------------------------------
# Get from: https://mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voltaria

# --------------------------------------------
# WEATHER API (Optional - for Weather Command)
# --------------------------------------------
# Get from: https://openweathermap.org/api
WEATHER_API_KEY=your_weather_api_key_here

# --------------------------------------------
# RAPIDAPI (Optional - for some Download Commands)
# --------------------------------------------
# Get from: https://rapidapi.com
RAPIDAPI_KEY=your_rapidapi_key_here

# --------------------------------------------
# GOOGLE API (Optional - for Google Search)
# --------------------------------------------
# Get from: https://console.cloud.google.com/apis
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here

# --------------------------------------------
# SPOTIFY API (Optional - for Spotify Search)
# --------------------------------------------
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# --------------------------------------------
# GENIUS API (Optional - for Lyrics)
# --------------------------------------------
# Get from: https://genius.com/api-clients
GENIUS_API_KEY=your_genius_api_key_here

# --------------------------------------------
# YOUTUBE API (Optional - for YouTube Search)
# --------------------------------------------
# Get from: https://console.cloud.google.com/apis
YOUTUBE_API_KEY=your_youtube_api_key_here

# --------------------------------------------
# GEMINI AI (Alternative to OpenAI)
# --------------------------------------------
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# PORT (For Deployment)
# --------------------------------------------
PORT=3000